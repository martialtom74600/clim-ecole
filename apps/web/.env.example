# ═══════════════════════════════════════════════════════════════════════════
# Clim École — apps/web (Next.js)
# ═══════════════════════════════════════════════════════════════════════════
#
# LOCAL (choisir UNE des deux options) :
#   A) Recommandé Next.js : cp .env.example .env.local  (reste dans apps/web/)
#   B) Monorepo          : variables dans /.env à la racine (partagées pipeline + web)
#
# VERCEL / PRODUCTION :
#   → Settings → Environment Variables (Production + Preview)
#   → Ne jamais commiter .env.local ni uploader de fichier secret
#
# ═══════════════════════════════════════════════════════════════════════════

# ── Obligatoire en production ───────────────────────────────────────────────

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Chaîne aléatoire 32+ caractères (sessions admin / client)
AUTH_SECRET=

# ── Admin cockpit (/admin) ──────────────────────────────────────────────────

ADMIN_PASSWORD=

# ── Stripe (checkout) ───────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_DOSSIER=price_...
STRIPE_PRICE_PRO=price_...

# ── Public (préfixe NEXT_PUBLIC_ = visible côté navigateur) ─────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3001
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=clim-ecole.fr

# ── Optionnel ───────────────────────────────────────────────────────────────

# Fallback CSV local si Supabase absent (dev uniquement)
# CLIM_CSV_PATH=../../output_prospection.csv

# Email transactionnel (Resend)
# RESEND_API_KEY=re_...
# EMAIL_FROM=Clim École <radar@example.com>

# Exclusivité territoires (défaut: 3)
# PACK_MAX_UNLOCKS=3

# Mode test — débloque tout sans Stripe (local + preview Vercel, jamais prod)
# CLIM_TEST_MODE=1

# Invalidation cache web après sync Supabase (même valeur que REVALIDATE_SECRET sur Vercel)
# REVALIDATE_SECRET=change-me-32-chars-minimum
