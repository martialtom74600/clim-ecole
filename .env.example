# Départements cibles (codes INSEE à 3 chiffres, séparés par des virgules)
# Raccourcis : AURA (12 dépts) | ALL | FRANCE | METROPOLE (101 dépts métropole + Corse)
DEPARTEMENTS=AURA
REGION_LABEL=Auvergne-Rhône-Alpes

# Filtre population communale (habitants)
POPULATION_MIN=2000
POPULATION_MAX=15000

# Filtre bâtiment (Décret Tertiaire — Sweet Spot patrimoine public communal EET)
# Import patrimoine : écoles (Education) + mairies/gymnases via CSV BDNB locaux (BPE, DPE tertiaire, adresses)
# npm run bdnb:reextract extrait ces tables depuis vos zip déjà téléchargés
# PATRIMOINE_IMPORT_DPE=1  # repli API ADEME uniquement si CSV BDNB absents
ANNEE_CONSTRUCTION_MAX=1990
SURFACE_MIN_M2=1000

# Moteur de filtrage EET (100 % dynamique — remplace tout hardcode patrimoine)
ELIGIBLE_SURFACE_MIN=1000
ELIGIBLE_PUBLIC_KEYWORDS=ecole,maternelle,elementaire,primaire,scolaire,mairie,hotel de ville,bibliotheque,centre de loisir,accueil de loisir
BANNED_PUBLIC_KEYWORDS=restaurant,restauration,pharmacie,psychologue,psy,macon,kinesitherapeute,agence,banque,auto-ecole,conduite,college,lycee,hopital
# Propriété foncière FFO/MAJIC (BDNB open) — formes juridiques publiques vs privées
# Collectivités territoriales uniquement (commune, EPCI) ; EPIC/EPA rejetés sauf dénomination COMMUNE/COMMUNAUTE
PUBLIC_OWNER_LEGAL_FORMS=COM,CCOM,METROPOLE,CU,CA,CC
PRIVATE_OWNER_LEGAL_FORMS=SCI,SARL,SAS,SA,SNC,SC,SCPI,SCM,SCOP,SCA,SCCP,AUPM,AUPE,AUDP,AUDA,ASS,FON,EARL,GAEC,GFA,GFR,GFO,GAF,STE,SLRL,SAM,SAFR,COAG,GIE,MUT,OPRO,SCEA,SICA
# EET_REQUIRE_LAND_OWNERSHIP=0  # désactive le filtre foncier (déconseillé)

# Rayon de recherche artisan RGE (km)
ARTISAN_RAYON_KM=30

# Tranche effectif INSEE minimum (11 = 10 à 19 salariés)
MIN_TRANCHE_EFFECTIF=11
# Intervalle min entre appels SIRENE (ms) — augmenter si 429 en région étendue
DELAY_SIRENE_MS=350

# Fichier de sortie
OUTPUT_FILE=output_prospection.csv
# Blacklist manuelle — UAI ou batiment_groupe_id (data/blacklist.json)
BLACKLIST_FILE=data/blacklist.json

# Filtre DPE tertiaire (anti-rénovations existantes — exclusion directe A/B/C)
DPE_GEO_RADIUS_M=200
DPE_EXCLUDE_GRADES=A,B,C
DPE_POST_YEAR_THRESHOLD=2022
DPE_LOW_CONSUMPTION_MAX=150
DELAY_DPE_MS=200

# Estimation financière CPE — Méthode 1 (prix SDES chargé au démarrage si réseau OK)
PRIX_KWH_MOYEN_TERTIAIRE=0.22
OBJECTIF_GAIN_CPE=0.45
TVA_COLLECTIVITES=0.20

# Modèle financier fourchette (optimiste / pessimiste) — défaut pipeline
# SUBSIDY_STACKING conservé pour compatibilité CEE forfait (optimiste legacy)
SUBSIDY_STACKING=realiste
SCENARIO_OPT_ECO_RATE=0.75
SCENARIO_OPT_SUBSIDY_RATE=0.80
SCENARIO_OPT_MGPE_RATE=0.04
SCENARIO_PES_ECO_RATE=0.55
SCENARIO_PES_SUBSIDY_RATE=0.45
SCENARIO_PES_MGPE_RATE=0.055
# Recalibrage adaptatif pessimiste (population INSEE, DPE F/G, Type_Travaux)
ADAPTIVE_RURAL_POP_THRESHOLD=3500
ADAPTIVE_SUBSIDY_RURAL_RATE=0.65
ADAPTIVE_SUBSIDY_URBAIN_RATE=0.45
ADAPTIVE_SUBSIDY_DPE_FG_BONUS=0.05
ADAPTIVE_ECO_LOURDE_RATE=0.70
ADAPTIVE_ECO_MOYENNE_RATE=0.55
ADAPTIVE_PAC_SEUIL_W_M2=60

# Correspondance INSEE → EPCI (CSV : Code_INSEE, Code_EPCI, Nom_EPCI)
# Si absent : cache .cache/insee-epci.json puis geo.api.gouv.fr
EPCI_MAPPING_FILE=data/insee_epci.csv
FONDS_VERT_REALISTIC_RATE=0.30
CPE_REALISATION_RATE=0.75
MGPE_PERFORMANCE_FLOOR=0.66
CEE_KWH_CUMAC_VALORISATION=0.008
CEE_MAX_SHARE_CAPEX_HT=0.12
SUBSIDY_THRESHOLD_SMALL=5000
SUBSIDY_THRESHOLD_MEDIUM=15000
SUBSIDY_RATE_SMALL=0.5
SUBSIDY_RATE_MEDIUM=0.4
SUBSIDY_RATE_LARGE=0.3
MAX_FONDS_ROI_YEARS_SOLO=12
MIN_PART_FONDS_SOLO=100000
MIN_PACKAGE_PART_FONDS=1000000

# Cache persistant + checkpoint (reprise après crash / Ctrl+C)
CACHE_DIR=.cache
RESET_CHECKPOINT=0

# Retries API BDNB (passes + cooldowns entre passes en secondes)
MAX_API_RETRY_PASSES=4
API_RETRY_COOLDOWNS_SEC=30,60,120,300

# Rate limiting (ms entre requêtes)
DELAY_EDUCATION_MS=250
DELAY_RNB_MS=300
DELAY_ANNUAIRE_MS=200
DELAY_GEO_MS=100
DELAY_ADEME_MS=200
DELAY_SDES_MS=300

# HTTP — retries illimités sur 429/5xx
HTTP_MAX_BACKOFF_MS=300000
HTTP_INITIAL_BACKOFF_MS=2000
HTTP_LOG_EVERY_N_RETRIES=5

# SIRENE — orchestrateur
SIRENE_MAX_INTERVAL_MS=8000
SIRENE_BACKOFF_MULTIPLIER=1.4

# BDNB — orchestrateur (token bucket + AIMD + singleflight)
# Quotas officiels (https://bdnb.io) :
#   Open (sans clé)     : 10 000 req/mois, 120 req/min/IP
#   Open Plus (clé)     : 1 000 000 req/mois, 1 200 req/min
# Clé obtenue sur https://api-portail.bdnb.io/ — en-tête X-Gravitee-Api-Key
# BDNB_API_TOKEN=
BDNB_SINGLE_REQUEST_EMBED=1
BDNB_BATCH_PREFETCH=1
BDNB_BATCH_SIZE=50
BDNB_MIN_INTERVAL_MS=3000
BDNB_MAX_INTERVAL_MS=15000
BDNB_BACKOFF_MULTIPLIER=1.5
BDNB_RECOVERY_MULTIPLIER=0.85
BDNB_RECOVERY_SUCCESS_THRESHOLD=8
BDNB_CIRCUIT_FAILURE_THRESHOLD=3
BDNB_CIRCUIT_COOLDOWN_MS=90000
RNB_CANDIDATES_PARALLEL=1

# Export CSV BDNB (0 €) — npm run bdnb:setup (télécharge + indexe)
BDNB_LOCAL_DIR=.cache/bdnb-local
BDNB_PREFER_LOCAL=1
# BDNB_MILLESIME=2026-02-a
# BDNB_LOCAL_ONLY=1

# Email de contact pour l'API RNB (recommandé)
RNB_FROM_EMAIL=contact@example.com

# Limite optionnelle pour les tests (0 = illimité)
MAX_SCHOOLS=0

# Parallélisation écoles (1 recommandé pour AURA+ — limite rate-limit BDNB)
SCHOOL_CONCURRENCY=1

# Sauvegarde checkpoint tous les N écoles
CHECKPOINT_SAVE_EVERY=5

DASHBOARD_PORT=3000
DASHBOARD_AUTO_REFRESH_SEC=30
# 0 = afficher les montants du CSV exporté (recommandé) · 1 = recalcul + re-clustering à chaque refresh
DASHBOARD_RECOMPUTE_FINANCE=0

# Token optionnel pour sécuriser POST /api/run (laisser vide = accès libre en local)
# DASHBOARD_API_TOKEN=

# Supabase — sync CSV → Postgres + site Next.js (un seul .env à la racine)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_PASSWORD=
# SUPABASE_SYNC_BATCH_SIZE=100

# ── Site Next.js (apps/web) ──
# Voir apps/web/.env.example pour la liste complète des variables web.
# Local : apps/web/.env.local (recommandé Next.js) OU les lignes ci-dessous dans ce fichier.

# CSV fallback local si Supabase absent (chemin depuis apps/web ou absolu)
# CLIM_CSV_PATH=../../output_prospection.csv

# Auth — AUTH_SECRET obligatoire en production (32+ caractères aléatoires)
# AUTH_SECRET=
# ADMIN_PASSWORD=

# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_DOSSIER=price_...
# STRIPE_PRICE_PRO=price_...
# NEXT_PUBLIC_APP_URL=http://localhost:3001
# REVALIDATE_SECRET=change-me-32-chars-minimum

# Exclusivité — max achats unitaires par territoire (défaut: 3)
# PACK_MAX_UNLOCKS=3

# Email transactionnel (Resend)
# RESEND_API_KEY=re_...
# EMAIL_FROM=Clim École <radar@example.com>

# Analytics (optionnel)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=clim-ecole.fr

# Mode test — débloque tous les territoires sans Stripe (local + preview Vercel)
# CLIM_TEST_MODE=1
